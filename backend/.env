PORT=5000
NODE_ENV=development

# ==============================================================
# GIGSHIELD CONFIGURATION
# ==============================================================

# 1. DATABASE
# Paste your MongoDB Atlas Connection String below.
# Example: mongodb+srv://username:password@cluster0.abc.mongodb.net/gigshield?retryWrites=true&w=majority
MONGODB_URI=

# 2. TWILIO SMS INTEGRATION (MOCKED BY DEFAULT)
# How to set up Twilio for real SMS:
# 1. Go to twilio.com and create a free account.
# 2. Get a free trial Twilio phone number.
# 3. Copy your Account SID and Auth Token from the console.
# 4. Paste them here to enable REAL SMS verification!
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
